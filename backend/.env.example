# Database
# Use SQLite for local dev (default):
DATABASE_URL=sqlite+aiosqlite:///./tlush_barur.db

# Use PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tlush_barur

# App
APP_ENV=development
SECRET_KEY=change-me-in-production-please

# Upload settings
MAX_UPLOAD_SIZE_MB=20
TRANSIENT_TTL_HOURS=1

# Logging
LOG_LEVEL=INFO
