# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
# PostgreSQL (production / preferred):
#   DATABASE_URL=postgresql://user:password@127.0.0.1:5432/tlush_barur
# SQLite (dev fallback – used automatically if left as placeholder):
#   DATABASE_URL=sqlite+aiosqlite:///./tlush_barur.db
# Leave as the placeholder below to auto-use SQLite in dev:
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/tlush_barur

# ---------------------------------------------------------------
# Retention / privacy
# ---------------------------------------------------------------
# How many hours until a transient upload expires and is auto-deleted.
# Default: 1.0 (one hour). Set to a very small value (e.g. 0.003 = ~10s) for testing.
TRANSIENT_TTL_HOURS=1.0

# How often (seconds) the cleanup loop runs. Default: 60.
CLEANUP_INTERVAL_SECONDS=60

# ---------------------------------------------------------------
# Application
# ---------------------------------------------------------------
APP_ENV=development
CORS_ORIGINS=http://127.0.0.1:5173
